@page "/admin/products"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IProductService ProductService

<PageTitle>Управление товарами</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Товары</h2>
        <a href="/admin" class="btn btn-outline-secondary btn-sm">← В админ-панель</a>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-white fw-bold">@(editingId == null ? "Добавить товар" : $"Редактировать товар #{editingId}")</div>
        <div class="card-body">
            <EditForm Model="@model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Название*</label>
                        <InputText class="form-control" @bind-Value="model.Name" />
                        <ValidationMessage For="() => model.Name" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Производитель</label>
                        <InputText class="form-control" @bind-Value="model.Manufacturer" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Действующее вещество</label>
                        <InputText class="form-control" @bind-Value="model.ActiveIngredient" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Цена*</label>
                        <InputNumber class="form-control" @bind-Value="model.Price" />
                        <ValidationMessage For="() => model.Price" class="text-danger small" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label">Описание</label>
                        <InputText class="form-control" @bind-Value="model.Description" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="model.IsPrescriptionRequired" id="presc" />
                            <label class="form-check-label" for="presc">По рецепту</label>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">@(editingId == null ? "Добавить" : "Сохранить")</button>
                    @if (editingId != null)
                    {
                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="ResetForm">Отмена</button>
                    }
                </div>
            </EditForm>
        </div>
    </div>

    @if (isLoading)
    {
        <p>Загрузка...</p>
    }
    else
    {
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Производитель</th>
                    <th>Вещество</th>
                    <th>Цена</th>
                    <th>Рецепт</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in products)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.Name</td>
                        <td>@p.Manufacturer</td>
                        <td>@p.ActiveIngredient</td>
                        <td>@p.Price.ToString("C")</td>
                        <td>@(p.IsPrescriptionRequired ? "Да" : "Нет")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditProduct(p)">Изм.</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(p.Id)">Удал.</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<AptekaDiplom2.Models.Product> products = new();
    private bool isLoading = true;
    private int? editingId;
    private string? message;
    private bool isError;

    private AptekaDiplom2.Models.Product model = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        products = await ProductService.GetAllProductsAsync();
        isLoading = false;
    }

    private void EditProduct(AptekaDiplom2.Models.Product p)
    {
        editingId = p.Id;
        model = new AptekaDiplom2.Models.Product
        {
            Id = p.Id,
            Name = p.Name,
            Description = p.Description,
            Price = p.Price,
            Manufacturer = p.Manufacturer,
            ActiveIngredient = p.ActiveIngredient,
            IsPrescriptionRequired = p.IsPrescriptionRequired
        };
    }

    private void ResetForm()
    {
        editingId = null;
        model = new AptekaDiplom2.Models.Product();
    }

    private async Task HandleSubmit()
    {
        if (editingId == null)
        {
            await ProductService.CreateProductAsync(model);
            message = $"Товар «{model.Name}» добавлен.";
        }
        else
        {
            model.Id = editingId.Value;
            await ProductService.UpdateProductAsync(model);
            message = $"Товар «{model.Name}» обновлён.";
        }
        isError = false;
        ResetForm();
        await LoadProducts();
    }

    private async Task DeleteProduct(int id)
    {
        var ok = await ProductService.DeleteProductAsync(id);
        if (ok)
        {
            message = "Товар удалён.";
            isError = false;
        }
        else
        {
            message = "Не удалось удалить товар (возможно, на него есть ссылки в заказах или остатках).";
            isError = true;
        }
        await LoadProducts();
    }
}
