@namespace AptekaDiplom2.Components
@inject AptekaDiplom2.State.CartState CartState
@implements IDisposable

<div class="nav-links">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
        <span>Каталог</span>
    </NavLink>

    <NavLink class="nav-link" href="cart">
        Корзина
        @if (CartState.GetTotalQuantity() > 0)
        {
            <span class="badge bg-danger rounded-pill ms-1">@CartState.GetTotalQuantity()</span>
        }
    </NavLink>

    <AuthorizeView>
        <Authorized>
            <NavLink class="nav-link" href="profile">Кабинет</NavLink>
            @if (context.User.IsInRole("Admin"))
            {
                <NavLink class="nav-link" href="admin">Админ</NavLink>
            }
            <form method="post" action="/api/auth/logout" class="d-inline nav-right">
                <AntiforgeryToken />
                <button type="submit" class="nav-link-btn">Выход</button>
            </form>
        </Authorized>
        <NotAuthorized>
            <NavLink class="nav-link nav-right" href="login">Войти</NavLink>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
    }
}