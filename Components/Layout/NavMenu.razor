@namespace AptekaDiplom2.Components
@inject AptekaDiplom2.State.CartState CartState
@implements IDisposable

<div class="top-row ps-3">
    <a href="">
        <span style="font-size: 1.5rem;">🌿</span>
        <span>AptekaDiplom2</span>
    </a>
</div>

<nav class="nav-scrollable">
    <!-- Главная -->
    <div class="nav-item">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <span>🏠</span> Главная
        </NavLink>
    </div>

    <!-- Каталог -->
    <div class="nav-item">
        <NavLink class="nav-link" href="catalog">
            <span>💊</span> Каталог
        </NavLink>
    </div>

    <!-- Корзина (с динамическим счетчиком) -->
    <div class="nav-item">
        <NavLink class="nav-link d-flex justify-content-between align-items-center" href="cart">
            <span>🛒 Корзина</span>

            @if (CartState.GetTotalQuantity() > 0)
            {
                <span class="badge bg-danger rounded-pill">@CartState.GetTotalQuantity()</span>
            }
        </NavLink>
    </div>

    <!-- Оформление заказа -->
    <div class="nav-item">
        <NavLink class="nav-link" href="checkout">
            <span>📝 Оформить</span>
        </NavLink>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="nav-item">
                <NavLink class="nav-link" href="profile">
                    <span>👤</span> Личный кабинет
                </NavLink>
            </div>

            @if (context.User.IsInRole("Admin"))
            {
                <div class="nav-item">
                    <NavLink class="nav-link" href="admin">
                        <span>⚙️</span> Администрирование
                    </NavLink>
                </div>
            }

            <div class="nav-item">
                <form method="post" action="/api/auth/logout">
                    <AntiforgeryToken />
                    <button type="submit" class="nav-link btn btn-link text-start w-100 border-0">
                        <span>🚪</span> Выйти (@context.User.Identity?.Name)
                    </button>
                </form>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-item">
                <NavLink class="nav-link" href="login">
                    <span>🔑</span> Войти
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="register">
                    <span>✍️</span> Регистрация
                </NavLink>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</nav>

@code {
    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
    }
}